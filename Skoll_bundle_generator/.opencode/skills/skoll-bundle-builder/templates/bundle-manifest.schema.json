{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skoll bundle manifest",
  "type": "object",
  "required": ["version", "stages"],
  "properties": {
    "version": {"type": "string"},
    "persona_hash": {"type": "string"},
    "stages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "timestamp"],
        "properties": {
          "status": {"enum": ["complete", "failed"]},
          "timestamp": {"type": "string"},
          "error": {"type": "string"}
        }
      }
    }
  }
}

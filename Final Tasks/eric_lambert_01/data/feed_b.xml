<?xml version="1.0" encoding="UTF-8"?>
<budgetConfig version="0.6" owner="Eric Lambert">
  <meta>
    <appName>budget.track</appName>
    <profile>school-year</profile>
    <currency>USD</currency>
    <createdOn>2025-11-14</createdOn>
    <lastEdited>2026-02-20</lastEdited>
    <note>Categories and thresholds mirror my real monthly plan so the summary view stays honest.</note>
  </meta>

  <categories>
    <category id="rent" type="fixed">
      <label>Rent</label>
      <monthlyThreshold>575.00</monthlyThreshold>
      <recurring>true</recurring>
      <alert>false</alert>
    </category>
    <category id="utilities" type="fixed">
      <label>Utilities, split three ways</label>
      <monthlyThreshold>70.00</monthlyThreshold>
      <recurring>true</recurring>
      <alert>false</alert>
    </category>
    <category id="phone" type="fixed">
      <label>Phone, family plan share</label>
      <monthlyThreshold>35.00</monthlyThreshold>
      <recurring>true</recurring>
      <alert>false</alert>
    </category>
    <category id="subscriptions" type="fixed">
      <label>Subscriptions</label>
      <monthlyThreshold>12.00</monthlyThreshold>
      <recurring>true</recurring>
      <alert>false</alert>
    </category>
    <category id="groceries" type="variable">
      <label>Groceries, personal share</label>
      <monthlyThreshold>200.00</monthlyThreshold>
      <recurring>false</recurring>
      <alert>true</alert>
    </category>
    <category id="dining" type="variable">
      <label>Dining and coffee</label>
      <monthlyThreshold>100.00</monthlyThreshold>
      <recurring>false</recurring>
      <alert>true</alert>
    </category>
    <category id="personal" type="variable">
      <label>Personal and thrifting</label>
      <monthlyThreshold>60.00</monthlyThreshold>
      <recurring>false</recurring>
      <alert>true</alert>
    </category>
    <category id="health" type="variable">
      <label>Health and pharmacy</label>
      <monthlyThreshold>25.00</monthlyThreshold>
      <recurring>false</recurring>
      <alert>false</alert>
    </category>
  </categories>

  <incomeSources>
    <source id="helpdesk">
      <label>Campus IT help desk</label>
      <expectedMonthly>1120.00</expectedMonthly>
      <frequency>biweekly</frequency>
    </source>
    <source id="tutoring">
      <label>Peer tutoring</label>
      <expectedMonthly>280.00</expectedMonthly>
      <frequency>monthly</frequency>
    </source>
    <source id="family">
      <label>Family contribution</label>
      <expectedMonthly>100.00</expectedMonthly>
      <frequency>monthly</frequency>
    </source>
  </incomeSources>

  <savingsGoal>
    <label>Emergency fund</label>
    <target>2000.00</target>
    <monthlyTransfer>200.00</monthlyTransfer>
    <account>checking-linked savings</account>
  </savingsGoal>

  <settings>
    <dateFormat>YYYY-MM-DD</dateFormat>
    <startOfMonth>1</startOfMonth>
    <roundingDisplay>2</roundingDisplay>
    <theme>light</theme>
    <archiveAfterMonths>6</archiveAfterMonths>
  </settings>
</budgetConfig>

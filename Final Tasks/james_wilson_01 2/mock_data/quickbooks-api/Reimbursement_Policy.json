{
  "policy_name": "Studio Expense & Reimbursement Policy",
  "version": "2025.Q1_Updated",
  "validation_rules": [
    {
      "rule": "Personal vs Business",
      "requirement": "Mixed personal/business charges",
      "action": "Split",
      "notes": "Only the business-use portion is recorded"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate receipts",
      "action": "Reject",
      "notes": "One receipt per transaction"
    },
    {
      "rule": "Missing Receipt",
      "requirement": "No receipt attached",
      "action": "Review",
      "notes": "Match against bank / Square records"
    },
    {
      "rule": "Unreadable Total",
      "requirement": "Illegible amount",
      "action": "Reject",
      "notes": "Re-scan or request a duplicate"
    },
    {
      "rule": "Late Entry",
      "requirement": "Logged after 30 days",
      "action": "Review",
      "notes": "Reconcile before quarter close"
    }
  ],
  "context": "Simple bookkeeping rules James uses to categorize Wilson Ceramics studio expenses at monthly and quarterly reconciliation."
}
<!-- Family recipe collection kept by Aaron Garcia. Quantities are home-batch sizes, not restaurant scale. -->
<recipes author="Aaron Nikolaos Garcia" tradition="Greek" updated="2025-11-30">
  <recipe id="r1" course="main" difficulty="advanced" serves="8">
    <name>Whole Lamb on the Spit</name>
    <occasion>Pascha</occasion>
    <prepHours>1.5</prepHours>
    <cookHours>5</cookHours>
    <ingredients>
      <ingredient qty="1" unit="whole">spring lamb, dressed</ingredient>
      <ingredient qty="6" unit="lemons">juiced</ingredient>
      <ingredient qty="1" unit="cup">extra virgin olive oil</ingredient>
      <ingredient qty="0.5" unit="cup">dried Greek oregano</ingredient>
      <ingredient qty="1" unit="head">garlic, crushed</ingredient>
      <ingredient qty="to taste" unit="">Aegean sea salt and black pepper</ingredient>
    </ingredients>
    <steps>
      <step>Brush the lamb inside and out with the lemon, oil, garlic, and oregano the night before.</step>
      <step>Truss it on the spit and balance it so it turns evenly.</step>
      <step>Roast low and slow over charcoal, basting every half hour, until the shoulder pulls clean.</step>
      <step>Rest before carving. Serve with lemon potatoes and horiatiki.</step>
    </steps>
    <note>The biggest day of the year. Forty plus guests in the backyard.</note>
  </recipe>
  <recipe id="r2" course="main" difficulty="moderate" serves="8">
    <name>Moussaka</name>
    <prepHours>1</prepHours>
    <cookHours>1.25</cookHours>
    <ingredients>
      <ingredient qty="3" unit="large">eggplant, sliced and salted</ingredient>
      <ingredient qty="2" unit="lb">ground lamb</ingredient>
      <ingredient qty="1" unit="can">crushed tomatoes</ingredient>
      <ingredient qty="1" unit="tsp">cinnamon</ingredient>
      <ingredient qty="3" unit="cups">bechamel</ingredient>
    </ingredients>
    <steps>
      <step>Fry or roast the eggplant until soft and lightly colored.</step>
      <step>Simmer the lamb with tomato and a touch of cinnamon until thick.</step>
      <step>Layer eggplant and meat, top with bechamel, and bake until golden.</step>
      <step>Let it set for twenty minutes so it slices clean.</step>
    </steps>
  </recipe>
  <recipe id="r3" course="dessert" difficulty="moderate" serves="24">
    <name>Baklava</name>
    <prepHours>1</prepHours>
    <cookHours>0.75</cookHours>
    <ingredients>
      <ingredient qty="1" unit="lb">phyllo dough</ingredient>
      <ingredient qty="4" unit="cups">walnuts, chopped</ingredient>
      <ingredient qty="1" unit="cup">melted butter</ingredient>
      <ingredient qty="1.5" unit="cups">Greek thyme honey syrup</ingredient>
      <ingredient qty="2" unit="tsp">cinnamon</ingredient>
    </ingredients>
    <steps>
      <step>Brush each phyllo layer with butter, alternating with the walnut and cinnamon mix.</step>
      <step>Score into diamonds before baking so the syrup soaks in.</step>
      <step>Bake until deep golden, then pour the warm honey syrup over the hot tray.</step>
    </steps>
  </recipe>
  <recipe id="r4" course="appetizer" difficulty="easy" serves="6">
    <name>Tzatziki</name>
    <prepHours>0.25</prepHours>
    <cookHours>0</cookHours>
    <ingredients>
      <ingredient qty="2" unit="cups">strained Greek yogurt</ingredient>
      <ingredient qty="1" unit="">cucumber, grated and squeezed dry</ingredient>
      <ingredient qty="2" unit="cloves">garlic, minced</ingredient>
      <ingredient qty="1" unit="tbsp">olive oil</ingredient>
      <ingredient qty="1" unit="splash">white wine vinegar</ingredient>
    </ingredients>
    <steps>
      <step>Fold everything together and season with salt.</step>
      <step>Chill at least an hour so the flavors marry.</step>
    </steps>
  </recipe>
</recipes>

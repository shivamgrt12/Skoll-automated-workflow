  <recipe id="BS-009" category="seasonal" origin="house" status="seasonal">
    <name>Hot Cross Buns, Easter</name>
    <description>Two-day technique, spiced enriched dough, fruit and citrus peel, cross paste and apricot glaze.</description>
    <yield>32 buns</yield>
    <bakers_percent>
      <ingredient flour="100">Bread flour</ingredient>
      <ingredient>Whole milk 56%</ingredient>
      <ingredient>Butter 16%</ingredient>
      <ingredient>Sugar 14%</ingredient>
      <ingredient>Egg 12%</ingredient>
      <ingredient>Mixed peel 22%</ingredient>
      <ingredient>Currants 30%</ingredient>
      <ingredient>Cinnamon 1.4%</ingredient>
      <ingredient>Allspice 0.6%</ingredient>
      <ingredient>Yeast 2%</ingredient>
      <ingredient>Salt 1.5%</ingredient>
    </bakers_percent>
    <process>
      <step day="1" time="14:00">Mix dough and bulk-ferment 90 minutes</step>
      <step day="1" time="16:00">Cold retard overnight</step>

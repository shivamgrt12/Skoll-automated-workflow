      <step day="2" time="06:30">Pipe crosses, bake 380 F, 18 minutes</step>
      <step day="2" time="07:00">Apricot glaze warm</step>
    </process>
    <notes>Customers order weeks ahead. 2027 production schedule starts Fri Apr 2.</notes>
    <last_edited>2026-01-08</last_edited>
  </recipe>


  <about>Private sourdough development log kept at home, separate from the Honeycomb production sheets. Each bake records flour blend, hydration, fermentation, and the verdict. Not for distribution.</about>
  <bakes>
    <bake date="2025-01-04" name="Plain Ruth Country">
      <flourBlend>100% bread flour</flourBlend>
      <hydration unit="percent">75</hydration>
      <starter unit="percent">20</starter>
      <salt unit="percent">2.0</salt>
      <bulkFerment unit="hours">5.5</bulkFerment>
      <fridgeRetard unit="hours">14</fridgeRetard>
      <bakeTemp unit="F">500</bakeTemp>
      <steam>yes</steam>
      <crust>thick, blistered</crust>

{
  "policy_name": "Personal Budgeting Notes",
  "version": "2026.Q1",
  "validation_rules": [
    {
      "rule": "Rent First",
      "requirement": "Apartment rent",
      "action": "Pay first of month",
      "notes": "Always clears before anything else"
    },
    {
      "rule": "Auto-Pay Check",
      "requirement": "Phone, utilities, insurance",
      "action": "Confirm",
      "notes": "Verify auto-pay posted from Navigant checking"
    },
    {
      "rule": "Prescriptions",
      "requirement": "Medicare and Rx co-pays",
      "action": "Track",
      "notes": "Watch this line, it varies month to month"
    },
    {
      "rule": "Savings",
      "requirement": "Monthly transfer to savings",
      "action": "Transfer",
      "notes": "Move $400 to Navigant savings after the bills clear"
    },
    {
      "rule": "Groceries",
      "requirement": "Weekly grocery spend",
      "action": "Review",
      "notes": "Keep Dave's around the $320/mo budget"
    }
  ],
  "context": "Simple personal reminders used when reviewing the monthly budget at home."
}

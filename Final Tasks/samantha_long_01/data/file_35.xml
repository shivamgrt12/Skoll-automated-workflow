  <companionPlanting>
    <pairing keep="together">Basil and marigold at the foot of the tomato row, against hornworms.</pairing>
    <pairing keep="together">Lettuce and arugula on the north side of the peppers, cut before the peppers shade them.</pairing>
    <pairing keep="apart">Zucchini in its own corner bed, wide spacing, watched for mildew in August.</pairing>
  </companionPlanting>

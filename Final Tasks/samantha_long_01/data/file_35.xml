  <seasonTimeline>
    <stage when="early February" task="Order seed list"/>
    <stage when="late February" task="Start tomatoes and peppers indoors by the window"/>
    <stage when="mid April" task="Direct sow lettuce and arugula"/>
    <stage when="early May" task="Harden off warm crops on the landing"/>
    <stage when="second week of May" task="Transplant tomatoes, peppers, zucchini"/>

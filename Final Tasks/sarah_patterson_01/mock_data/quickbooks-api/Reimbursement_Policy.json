{
  "policy_name": "Freelance Expense Check Rules",
  "version": "2026.Personal",
  "validation_rules": [
    {
      "rule": "Personal vs Gig",
      "requirement": "Mixed personal + freelance charges",
      "action": "Manual Review",
      "notes": "Only split out the gig-related portion"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate uploads",
      "action": "Reject",
      "notes": "Only one valid receipt allowed"
    },
    {
      "rule": "Reprints",
      "requirement": "Reprint receipts",
      "action": "Review",
      "notes": "Need bank match"
    },
    {
      "rule": "Missing Total",
      "requirement": "Unreadable totals",
      "action": "Reject",
      "notes": "Low OCR confidence"
    },
    {
      "rule": "Late Submission",
      "requirement": "Logged after 30 days",
      "action": "Reject",
      "notes": "Skip - not worth chasing at tax time"
    }
  ],
  "context": "Loose rules I use when sorting freelance comms receipts from personal spending at tax time."
}

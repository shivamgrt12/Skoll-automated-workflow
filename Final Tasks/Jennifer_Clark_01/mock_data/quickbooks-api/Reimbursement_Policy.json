{
  "policy_name": "Reimbursement Policy",
  "version": "2026.Q3",
  "validation_rules": [
    {
      "rule": "Threshold",
      "requirement": "Line items over 500 USD",
      "action": "Board treasurer review",
      "notes": "Ensures capital-adjacent purchases get sign-off"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate receipt uploads",
      "action": "Reject",
      "notes": "Only one valid receipt per line"
    },
    {
      "rule": "Missing Total",
      "requirement": "Unreadable totals",
      "action": "Reject",
      "notes": "Low OCR confidence"
    },
    {
      "rule": "Late Submission",
      "requirement": "After 30 days",
      "action": "Reject",
      "notes": "Policy violation"
    },
    {
      "rule": "Personal Use",
      "requirement": "Non-museum context",
      "action": "Reject",
      "notes": "Strict separation of household spend"
    }
  ],
  "context": "Rules used when validating card and receipt submissions from curatorial and operations staff."
}
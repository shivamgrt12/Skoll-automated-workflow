{
  "policy_name": "Reimbursement Policy",
  "version": "2026.Q1_Personal",
  "validation_rules": [
    {
      "rule": "MedicalReceipts",
      "requirement": "Rx and clinic receipts",
      "action": "Auto-approve",
      "notes": "For personal FSA / HSA tracking"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate uploads",
      "action": "Reject",
      "notes": "Only one valid receipt allowed"
    },
    {
      "rule": "IllegibleTotal",
      "requirement": "Unreadable totals",
      "action": "Manual Review",
      "notes": "Ask pharmacist for reprint"
    },
    {
      "rule": "LateSubmission",
      "requirement": "After 90 days",
      "action": "Reject",
      "notes": "IRS tax-year cutoff"
    },
    {
      "rule": "GardenClubDues",
      "requirement": "Cedar Hills Garden Club expenses",
      "action": "Route to GC treasurer books",
      "notes": "Not personal reimbursable"
    }
  ],
  "context": "Personal reimbursement/tracking policy for Rx, medical, and Garden Club treasurer books."
}
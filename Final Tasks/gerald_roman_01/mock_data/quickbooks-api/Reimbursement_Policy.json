      "requirement": "Unreadable totals",
      "action": "Reject",
      "notes": "Low OCR confidence"
    },
    {
      "rule": "Late Entry",
      "requirement": "Logged after 30 days",
      "action": "Review",
      "notes": "Reconcile against settled payment-rail records"
    }

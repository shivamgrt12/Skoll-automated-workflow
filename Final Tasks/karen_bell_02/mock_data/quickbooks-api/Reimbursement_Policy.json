{
  "policy_name": "Reimbursement Policy",
  "version": "2024.Q4_Updated",
  "validation_rules": [
    {
      "rule": "Alcohol",
      "requirement": "Alcohol-heavy charges",
      "action": "Manual Review",
      "notes": "Client meals only"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate uploads",
      "action": "Reject",
      "notes": "Only one valid receipt allowed"
    },
    {
      "rule": "Reprints",
      "requirement": "Reprint receipts",
      "action": "Review",
      "notes": "Need bank match"
    },
    {
      "rule": "Missing Total",
      "requirement": "Unreadable totals",
      "action": "Reject",
      "notes": "Low OCR confidence"
    },
    {
      "rule": "Late Submission",
      "requirement": "After 30 days",
      "action": "Reject",
      "notes": "Policy violation"
    },
    {
      "rule": "Mileage",
      "requirement": "Personal vehicle travel",
      "action": "Approve",
      "notes": "IRS standard rate; log start/end addresses"
    },
    {
      "rule": "Conference Registration",
      "requirement": "APNA / FNA / CME events",
      "action": "Approve",
      "notes": "Pre-approval by Karen Bell required"
    },
    {
      "rule": "Personal Items",
      "requirement": "Non-business purchases",
      "action": "Reject",
      "notes": "Not reimbursable under S-corp policy"
    },
    {
      "rule": "Cash Receipts",
      "requirement": "Cash-paid purchases",
      "action": "Review",
      "notes": "Itemized receipt mandatory"
    },
    {
      "rule": "Tips Excessive",
      "requirement": "Gratuity over 20%",
      "action": "Manual Review",
      "notes": "Cap reimbursable tip at 20%"
    },
    {
      "rule": "Office Supplies",
      "requirement": "Office Depot / Staples",
      "action": "Approve",
      "notes": "Within monthly supplies budget"
    },
    {
      "rule": "Postage & Shipping",
      "requirement": "US Post Office / courier",
      "action": "Approve",
      "notes": "Practice correspondence only"
    },
    {
      "rule": "Membership Dues",
      "requirement": "Professional org memberships",
      "action": "Approve",
      "notes": "APNA, FNA, NAMI - clinician dues"
    },
    {
      "rule": "Foreign Currency",
      "requirement": "Non-USD charges",
      "action": "Manual Review",
      "notes": "Convert at posted exchange rate"
    },
    {
      "rule": "Missing Receipt",
      "requirement": "No receipt attached",
      "action": "Reject",
      "notes": "Receipt required over $25"
    },
    {
      "rule": "Tax Mismatch",
      "requirement": "Sales tax inconsistent",
      "action": "Review",
      "notes": "Verify against merchant total"
    },
    {
      "rule": "Split Charges",
      "requirement": "Single purchase split",
      "action": "Manual Review",
      "notes": "Possible limit circumvention"
    },
    {
      "rule": "Telehealth Software",
      "requirement": "EHR / platform fees",
      "action": "Approve",
      "notes": "Tag to Technology & EHR account"
    },
    {
      "rule": "Meals Solo",
      "requirement": "Single-person meals",
      "action": "Review",
      "notes": "Travel days only; per diem applies"
    },
    {
      "rule": "Pre-Approval",
      "requirement": "Charges over $500",
      "action": "Manual Review",
      "notes": "Requires Karen Bell sign-off in advance"
    }
  ],
  "context": "Rules used during reimbursement validation for conference meal receipts."
}
    "like_count": "19",
    "hidden": "false",
    "parent_id": "17800500024"
  },
  {
    "id": "17800500010",
    "media_id": "17900500008",
    "user_id": "17841401556000005",
    "username": "sofia_nyman_author",
    "text": "Vi ses imorgon! Jag ser fram emot kväll hos er - de bästa värdarna i Uppsala.",
    "timestamp": "2025-03-26T17:00:00",
    "like_count": "45",
    "hidden": "false",
    "parent_id": "17800500004"
  },
  {

  {
    "id": "block-jan-002",
    "page_id": "page-meeting-jan",
    "parent_block_id": "",
    "type": "paragraph",
    "text": "We met at the Glastonbury Library, 10 AM on the first Saturday. Attendees: Jenny, Peggy, Audrey, Dorothy. Book: Excellent Women by Barbara Pym.",
    "order": "1",
    "created_time": "2026-01-03T11:06:00.000Z",
    "last_edited_time": "2026-01-03T13:30:00.000Z",
    "has_children": "false",
    "checked": null
  },
  {
    "id": "block-jan-003",
    "page_id": "page-meeting-jan",
    "parent_block_id": "",
    "type": "bulleted_list_item",
    "text": "Mildred Lathbury's wry self-awareness drew unanimous praise from the group.",
    "order": "2",
    "created_time": "2026-01-03T11:07:00.000Z",
    "last_edited_time": "2026-01-03T13:30:00.000Z",
    "has_children": "false",
    "checked": null
  },
  {
    "id": "block-jan-004",
    "page_id": "page-meeting-jan",
    "parent_block_id": "",
    "type": "bulleted_list_item",
    "text": "Peggy noted the parallel between 1950s church life and our own Glastonbury routines.",
    "order": "3",
    "created_time": "2026-01-03T11:08:00.000Z",
    "last_edited_time": "2026-01-03T13:30:00.000Z",
    "has_children": "false",
    "checked": null
  },
  {
    "id": "block-jan-005",
    "page_id": "page-meeting-jan",
    "parent_block_id": "",
    "type": "paragraph",
    "text": "Next meeting: February 7. Book: The Gate of Angels by Penelope Fitzgerald. Dorothy will bring refreshments.",

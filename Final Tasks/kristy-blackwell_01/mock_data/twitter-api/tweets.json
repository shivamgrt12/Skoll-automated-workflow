  {
    "id": "9147758587948147811",
    "author_id": "8612186626201475369",
    "text": "New porcelain vessels drying in the studio. If the humidity cooperates they will be ready to bisque next week.",
    "created_at": "2025-10-13T16:20:00+00:00",
    "lang": "en",

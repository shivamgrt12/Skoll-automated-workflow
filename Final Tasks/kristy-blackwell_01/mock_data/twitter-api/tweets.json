    "lang": "en",
    "reply_to_tweet_id": "1780000000000006026",
    "like_count": "129",
    "retweet_count": "37",
    "reply_count": "3",
    "quote_count": "1"
  },
  {
    "id": "8305881155635351087",
    "author_id": "6120345678901234501",
    "text": "Announcing our fall solo exhibition: Vessel as Landscape by Kristy Blackwell, opening October 17. Large-scale ceramic vessels from the Albuquerque artist.",

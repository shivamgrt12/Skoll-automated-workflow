  {
    "chat_id": "7531294510",
    "date": "1771699680",
    "from_id": "4540104028",
    "message_id": "1000013",
    "reply_to_message_id": "1000000",
    "text": "Two bass and a catfish before lunch. Good day. Manny's Tacos on the way home?"

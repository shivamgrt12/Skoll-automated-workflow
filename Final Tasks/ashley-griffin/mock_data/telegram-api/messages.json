    "message_id": "1000000",
    "reply_to_message_id": "1000000",
    "text": "Drove past Parker Canyon today. Water's up about a foot from last month, ramp's clear."
  },
  {
    "chat_id": "7531294510",
    "date": "1768094400",
    "from_id": "4540104028",
    "message_id": "1000001",
    "reply_to_message_id": "1000000",
    "text": "Nice. No custody this Saturday so I'm in. Bass or trout?"
  },
  {
    "chat_id": "7531294510",
    "date": "1768094640",
    "from_id": "7531294510",
    "message_id": "1000002",
    "reply_to_message_id": "1000000",
    "text": "Trout still hitting near the dam, they stocked it before Christmas. Bring the light rods."
  },
  {
    "chat_id": "7531294510",
    "date": "1768657200",
    "from_id": "7531294510",
    "message_id": "1000003",
    "reply_to_message_id": "1000000",
    "text": "Heading out at first light. Pic of the level this morning, looks good."
  },
  {
    "chat_id": "7531294510",
    "date": "1768658100",
    "from_id": "4540104028",
    "message_id": "1000004",
    "reply_to_message_id": "1000000",
    "text": "On my way from Sierra Vista, give me 50 min. Coffee's in the truck."
  },
  {
    "chat_id": "7531294510",
    "date": "1769301600",
    "from_id": "4540104028",
    "message_id": "1000007",
    "reply_to_message_id": "1000000",
    "text": "Working a furnace call till 3 but could swing by after. Save me a spot."
  },
  {
    "chat_id": "7531294510",
    "date": "1770473700",
    "from_id": "7531294510",
    "message_id": "1000008",
    "reply_to_message_id": "1000000",
    "text": "Level dropped a bit after that dry stretch. Still plenty of water on the main ramp."
  },
  {
    "chat_id": "7531294510",
    "date": "1771112700",
    "from_id": "4540104028",
    "message_id": "1000016",
    "reply_to_message_id": "1000000",
    "text": "Bite slowed with the front but mornings are still solid. Go early."
  },
  {
    "chat_id": "7531294510",
    "date": "1771120920",
    "from_id": "7531294510",
    "message_id": "1000010",
    "reply_to_message_id": "1000000",
    "text": "No-custody Saturday next week. You good to run the lake with me?"
  },
  {
    "chat_id": "7531294510",
    "date": "1771121400",
    "from_id": "4540104028",
    "message_id": "1000011",
    "reply_to_message_id": "1000000",
    "text": "Yeah my daughter's with her mom that weekend. I'll grab the trolling motor battery."
  },
  {
    "chat_id": "7531294510",
    "date": "1771680600",
    "from_id": "7531294510",
    "message_id": "1000012",
    "reply_to_message_id": "1000000",
    "text": "First light again. Lake's glassy, water clear down six feet."

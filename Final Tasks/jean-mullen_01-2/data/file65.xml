<?xml version="1.0" encoding="UTF-8"?>
<academy name="Ceili Mor Academy of Dance" founded="2012">
  <profile>
    <address line1="First Floor, 22 Luz Church Road" area="Mylapore" city="Chennai" postcode="600004"/>
    <director>Jean Mullen</director>
    <discipline>Contemporary and Irish dance, Munster tradition</discipline>
    <enrolment activeStudents="35" term="Term 2, 2025 to 2026"/>
  </profile>

  <levels>
    <level id="beginners" ageFrom="6" monthlyFeeINR="2800">
      <focus>Soft shoe basics, posture, rhythm, first steps in listening to the music.</focus>
    </level>
    <level id="intermediate" ageFrom="11" monthlyFeeINR="3500">
      <focus>Hard shoe trebles, slip jig timing, following the bodhran without a cue.</focus>
    </level>
    <level id="advanced" ageFrom="14" monthlyFeeINR="4500">
      <focus>Full tempo hard shoe, repertoire, and troupe selection for those who earn it.</focus>
    </level>
    <level id="adultOpen" ageFrom="18" monthlyFeeINR="3800">
      <focus>Evening open class for adult dancers, movement and rhythm without exam pressure.</focus>
    </level>
  </levels>

  <weeklySchedule>
    <day name="Monday">
      <class level="beginners" start="10:00" end="12:00"/>
      <class level="intermediate" start="15:00" end="17:00"/>
      <class level="advanced" start="17:30" end="19:30"/>
    </day>
    <day name="Tuesday">
      <class level="beginners" start="10:00" end="12:00"/>
      <class level="advanced" start="17:30" end="19:30"/>
    </day>
    <day name="Wednesday">
      <class level="intermediate" start="10:00" end="12:00"/>
      <class level="advanced" type="rehearsal" start="17:30" end="19:30"/>
    </day>
    <day name="Thursday">
      <class level="beginners" start="11:00" end="12:30"/>
      <class level="advanced" start="17:30" end="19:30"/>
    </day>
    <day name="Friday">
      <class level="intermediate" start="10:00" end="12:00"/>
      <class type="private" student="Emma Walsh" detail="solo debut coaching" start="15:00" end="17:00"/>
    </day>
    <day name="Saturday">
      <class type="rehearsal" detail="Production troupe intensive" start="07:00" end="11:00"/>
      <class level="beginners" start="11:30" end="13:00"/>
    </day>
  </weeklySchedule>


{
  "policy_name": "Eastwick Prep Chess Team Reimbursement Policy",
  "version": "2026-2027 Academic Year",
  "validation_rules": [
    {
      "rule": "Tournament Entry",
      "requirement": "Pre-approved by Principal Reyes",
      "action": "Reimburse",
      "notes": "Submit entry receipt within 14 days of tournament"
    },
    {
      "rule": "Travel Mileage",
      "requirement": "IRS standard rate, pre-approved route",
      "action": "Reimburse",
      "notes": "Log must include date, destination, odometer readings"
    },
    {
      "rule": "Equipment Purchase",
      "requirement": "Chess boards, clocks, books under $200",
      "action": "Reimburse",
      "notes": "Over $200 requires separate purchase order"
    },
    {
      "rule": "Team Meals",
      "requirement": "Tournament day meals, max $12/student",
      "action": "Reimburse",
      "notes": "Itemized receipt required, no alcohol"
    },
    {
      "rule": "Late Submission",
      "requirement": "After 30 days",
      "action": "Reject",
      "notes": "School district fiscal policy"
    }
  ],
  "context": "Rules for chess team coaching expense reimbursement. Submit to Principal Gloria Reyes with receipts attached."
}

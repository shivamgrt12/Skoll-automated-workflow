    "page_id": "p7f5d96f0ade3620917e4000e3d150f19",
    "parent_block_id": null,
    "text": "Flushing Night Market — 40-06 Prince St plaza; peak 9 PM–midnight; wet asphalt + red lantern signature.",
    "type": "bulleted_list_item"
  },
  {
    "checked": null,
    "created_time": "2026-11-01T14:00:00Z",
    "has_children": "false",
    "id": "b33cfdbf124be74c7f32624eb2b79b815",
    "last_edited_time": "2026-10-01T19:00:00Z",
    "order": 4,
    "page_id": "p7f5d96f0ade3620917e4000e3d150f19",
    "parent_block_id": null,
    "text": "Sunset Park 8th Ave — dumpling row after 10 PM; steam plumes off the pot windows.",
    "type": "bulleted_list_item"
  },
  {
    "checked": null,
    "created_time": "2026-11-01T15:00:00Z",
    "has_children": "false",
    "id": "b8862340060f5e57d1af4aed935cbfb84",
    "last_edited_time": "2026-10-01T20:00:00Z",
    "order": 5,
    "page_id": "p7f5d96f0ade3620917e4000e3d150f19",
    "parent_block_id": null,
    "text": "Jackson Heights 74th St — samosa carts + kebab stands; awning-lit + street-lit.",

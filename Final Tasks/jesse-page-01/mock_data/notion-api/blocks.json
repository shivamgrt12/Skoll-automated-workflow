    "page_id": "pe0d17360314901268d70278a556d2d7c",
    "parent_block_id": null,
    "text": "Ochre + sage linen palette. Ceramic from Ana's shelf where possible.",
    "type": "bulleted_list_item"
  },
  {
    "checked": null,
    "created_time": "2026-11-02T12:00:00Z",
    "has_children": "false",
    "id": "bf2b8e2224ad9d6e3c7e2dfa4018cef89",

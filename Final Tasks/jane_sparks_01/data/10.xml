<?xml version="1.0" encoding="UTF-8"?>
<recipebox baker="Jane Sparks">
  <recipe name="Cinnamon Rolls">
    <ingredients>
      <item>flour 4 cups</item>
      <item>active dry yeast 2.25 tsp</item>
      <item>whole milk 1 cup</item>
      <item>butter 1/3 cup</item>
      <item>brown sugar 1 cup</item>
      <item>cinnamon 2.5 tbsp</item>
      <item>cream cheese frosting</item>
    </ingredients>
    <steps>
      <step n="1">Proof yeast in warm milk.</step>
      <step n="2">Knead dough, rise 1 hour.</step>
      <step n="3">Roll, spread cinnamon sugar, slice.</step>
      <step n="4">Second rise 30 min.</step>
      <step n="5">Bake 350F for 22 minutes.</step>
      <step n="6">Frost warm.</step>
    </steps>
  </recipe>
  <recipe name="Pecan Pie">
    <ingredients>
      <item>pie crust 1</item>
      <item>pecan halves 1.5 cups</item>
      <item>corn syrup 1 cup</item>
      <item>brown sugar 1 cup</item>
      <item>eggs 3</item>
      <item>butter 4 tbsp</item>
      <item>vanilla 1 tsp</item>
      <item>salt 0.5 tsp</item>
    </ingredients>
    <steps>
      <step n="1">Whisk filling.</step>
      <step n="2">Layer pecans in crust.</step>
      <step n="3">Pour filling.</step>
      <step n="4">Bake 350F for 55 minutes.</step>
      <step n="5">Cool fully before slicing.</step>
    </steps>
  </recipe>
  <recipe name="Pound Cake">
    <ingredients>
      <item>butter 1 lb</item>
      <item>sugar 3 cups</item>
      <item>eggs 6</item>
      <item>flour 3 cups</item>
      <item>milk 1 cup</item>
      <item>vanilla 1 tbsp</item>
    </ingredients>
    <steps>
      <step n="1">Cream butter and sugar.</step>
      <step n="2">Add eggs one at a time.</step>
      <step n="3">Alternate flour and milk.</step>
      <step n="4">Bake 325F for 75 minutes in a tube pan.</step>
      <step n="5">Cool 20 minutes before turning out.</step>
    </steps>
  </recipe>
</recipebox>

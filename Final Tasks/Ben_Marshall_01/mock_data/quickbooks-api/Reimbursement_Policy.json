{
  "policy_name": "Volunteer Reimbursement Policy",
  "version": "2026.Outreach",
  "validation_rules": [
    {
      "rule": "Mileage",
      "requirement": "Volunteer travel for outreach activities",
      "action": "Approve",
      "notes": "Standard mileage rate; log trip purpose and date"
    },
    {
      "rule": "Materials",
      "requirement": "Program supplies purchased by volunteers",
      "action": "Approve",
      "notes": "Itemized receipt required"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate submissions",
      "action": "Reject",
      "notes": "Only one valid receipt allowed"
    },
    {
      "rule": "Missing Receipt",
      "requirement": "No receipt attached",
      "action": "Hold",
      "notes": "Pending until receipt provided"
    },
    {
      "rule": "Late Submission",
      "requirement": "Submitted after 30 days",
      "action": "Committee Review",
      "notes": "Outreach lead approval needed"
    }
  ],
  "context": "Rules used when reviewing Grace Community Church outreach volunteer reimbursement requests."
}

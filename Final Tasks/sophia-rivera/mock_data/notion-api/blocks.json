    "checked": ""
  },
  {
    "id": "nblk-meds-01",
    "page_id": "npg-mom-meds",
    "type": "paragraph",
    "order": "1",
    "created_time": "2024-04-11T09:15:00-06:00",
    "text": "NO NSAIDs (ibuprofen, naproxen, aspirin). Sophia is on Eliquis. If in doubt, acetaminophen only. Sulfa allergy on file.",
    "parent_block_id": "",
    "last_edited_time": "2024-04-11T09:15:00-06:00",
    "has_children": "false",
    "checked": ""
  },
  {
    "id": "nblk-meds-02",
    "page_id": "npg-mom-meds",
    "type": "paragraph",
    "order": "2",
    "created_time": "2026-01-15T09:00:00-06:00",
    "text": "A1C target under 7.0. Last reading Jan 2026 was 7.1.",
    "parent_block_id": "",
    "last_edited_time": "2026-01-15T09:00:00-06:00",
    "has_children": "false",
    "checked": ""
  },
  {
    "id": "nblk-contacts-01",
    "page_id": "npg-mom-contacts",
    "type": "paragraph",
    "order": "1",
    "created_time": "2024-04-11T09:22:00-06:00",
    "text": "911 for chest pain, stroke signs, fall with head impact, severe hypoglycemia, or AFib episode with new symptoms. THEN Elena. Marco second. Rosa Delgado next-door for on-property fallback.",
    "parent_block_id": "",
    "last_edited_time": "2024-04-11T09:22:00-06:00",
    "has_children": "false",
    "checked": ""
  },

[
  {
    "id": "rev-IU9z2i2FId",
    "business_id": "biz-blackcoffee-001",
    "rating": "5",
    "text": "My morning stop before BRC every single weekday. The pour-overs are the best in Missoula and they know my order by now. Reliable, quiet, good wifi.",
    "user_name": "Ava R.",
    "time_created": "2026-03-08T08:15:00"
  },
  {
    "id": "rev-68gRaLK6bs",
    "business_id": "biz-blackcoffee-001",
    "rating": "4",
    "text": "Great single-origin selection. Gets a bit crowded mid-morning but the coffee quality holds up.",
    "user_name": "Liam T.",
    "time_created": "2026-03-20T09:30:00"
  },
  {
    "id": "rev-fRIignmj-W",
    "business_id": "biz-tophat-00002",
    "rating": "5",
    "text": "Best live music venue in western Montana. Saw a bluegrass act here last month and the sound was perfect. Cold beer, friendly crowd.",
    "user_name": "Noah K.",
    "time_created": "2026-03-03T22:00:00"
  },
  {
    "id": "rev-PtJ8kaWJHA",
    "business_id": "biz-kettle-00003",
    "rating": "5",
    "text": "Cold Smoke is the move every time. Love the taproom - good seating and not too loud. The Northside location feels more relaxed.",
    "user_name": "Mia S.",
    "time_created": "2026-03-22T18:45:00"
  },
  {
    "id": "rev-E6ywljrSpv",
    "business_id": "biz-kettle-00003",
    "rating": "4",
    "text": "Solid local brewery. The amber is underrated. Nice spot to decompress after a long clinic day.",
    "user_name": "Ethan B.",
    "time_created": "2026-03-15T17:50:00"
  },
  {
    "id": "rev-HMbFV3eqGk",
    "business_id": "biz-pearlcafe-0004",
    "rating": "5",
    "text": "Some of the best meal in Missoula. The menu changes with the season. I come here when I want a real meal. Reservation recommended on weekends.",
    "user_name": "Zoe M.",
    "time_created": "2026-02-14T19:30:00"
  },
  {
    "id": "rev-8eP22YcNuT",
    "business_id": "biz-msoathclub-10",
    "rating": "5",
    "text": "Best bouldering gym in town. Small but the routesetters keep it fresh. Community is welcoming to newer climbers. I am here 3x a week.",
    "user_name": "Lucas P.",
    "time_created": "2026-03-18T19:00:00"
  },
  {
    "id": "rev-zDL0AB7Zx9",
    "business_id": "biz-msoathclub-10",
    "rating": "4",
    "text": "Good gym for climbing and strength work. The V4-V6 section has solid variety. Parking can be tricky.",
    "user_name": "Emma W.",
    "time_created": "2026-03-10T18:30:00"
  },
  {
    "id": "rev-9vl7uOSohH",
    "business_id": "biz-bigdipper-006",
    "rating": "5",
    "text": "Local institution. The huckleberry is iconic. Go after a long hike - you have earned it.",
    "user_name": "Mason D.",
    "time_created": "2026-03-10T15:20:00"
  },
  {
    "id": "rev-PBJ2z7cq-d",
    "business_id": "biz-butterfly-09",
    "rating": "4",
    "text": "Great selection of loose leaf teas and dried herbs. The staff actually knows their inventory. I picked up a koji starter here that worked perfectly.",
    "user_name": "Olivia F.",
    "time_created": "2026-03-28T12:45:00"
  },
  {
    "id": "rev-DsqlSukvt7",
    "business_id": "biz-freestone-011",
    "rating": "5",
    "text": "Bigger wall space than The Gym and the rope setup is great for working endurance. Spent a rainy Saturday projecting a V4 here and the setters had clearly thought it through. Friendly desk staff.",
    "user_name": "Jack H.",
    "time_created": "2026-03-24T14:10:00"
  },
  {
    "id": "rev-ZYoBcA3Ja_",
    "business_id": "biz-freestone-011",
    "rating": "4",
    "text": "Solid bouldering and a decent fitness area. Gets packed on weeknights in winter but the routesetting rotation is consistent.",
    "user_name": "Sofia L.",
    "time_created": "2026-03-28T19:15:00"
  },
  {
    "id": "rev-qOAWZAENmS",
    "business_id": "biz-trailhead-012",
    "rating": "5",
    "text": "Picked up new trail running shoes here and the staff actually run the local trails, so the advice was spot on. They sized me for a pack for a Rattlesnake overnight too. Local, knowledgeable, no pressure.",
    "user_name": "Leo G.",
    "time_created": "2026-03-19T11:30:00"
  },
  {
    "id": "rev-R_Scs-yiqb",
    "business_id": "biz-rei-0000013",
    "rating": "4",
    "text": "Good for restocking the basics and the gear is dependable. Used a dividend on new XC ski poles last fall. Wish they carried more local brands, but the return policy is unbeatable.",
    "user_name": "Nora V.",
    "time_created": "2026-01-22T16:40:00"
  },
  {
    "id": "rev-eg-CtkykTU",
    "business_id": "biz-factmotion-14",
    "rating": "5",
    "text": "Got my classic cross-country skis waxed and tuned here before a trip up to Lolo Pass. The tech walked me through kick wax for the conditions. These folks know nordic gear.",
    "user_name": "Owen C.",
    "time_created": "2026-02-07T17:05:00"
  },
  {
    "id": "rev-8ml9bZ-FJ4",
    "business_id": "biz-factread-015",
    "rating": "5",
    "text": "My go-to for literary fiction. The staff picks shelf is reliably excellent and they special-order anything they do not stock. Found a beautiful regional cookbook here last week. Independent bookstores matter.",
    "user_name": "Ruby A.",
    "time_created": "2026-03-12T13:00:00"
  },
  {
    "id": "rev-wUEE12zfcx",
    "business_id": "biz-greenhouse-17",
    "rating": "5",
    "text": "My apartment is basically a jungle now and it is mostly their fault. Great selection of pothos and a healthy fiddle leaf fig that has thrived. The owner gives honest care advice for our dry winters.",
    "user_name": "Eli N.",
    "time_created": "2026-03-28T15:25:00"
  },
  {
    "id": "rev-xpI0sL-Ara",
    "business_id": "biz-goodmeal-018",
    "rating": "5",
    "text": "I do most of my real grocery shopping here. Great bulk section for the cooking experiments, solid produce, and the hot counter is clutch after a clinic day. Parking lot is a zoo at 5pm though.",
    "user_name": "Iris J.",
    "time_created": "2026-03-26T18:20:00"
  },
  {
    "id": "rev-cfAAmbFrwe",
    "business_id": "biz-leighlomas-19",
    "rating": "5",
    "text": "The baguettes are the best in town and the morning croissants disappear fast. I grab a loaf on my way back from the Sentinel trailhead most weekends. Tiny shop, big quality.",
    "user_name": "Cole M.",
    "time_created": "2026-03-02T09:45:00"
  },
  {
    "id": "rev---vKq9tHQR",
    "business_id": "biz-mtsentinel-20",
    "rating": "5",
    "text": "The M trail and the full ridge run to the summit is my reset button. Quick access from town, brutal switchbacks, and the view of the valley from the top is worth every step. I run it before work in summer.",

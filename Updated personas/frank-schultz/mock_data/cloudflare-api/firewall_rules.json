[
  {
    "id": "fw0001fai",
    "zone_id": "zone-MCWC Chronic Pain Program-ai-0001",
    "description": "Block known bad bot user agents",
    "action": "block",
    "expression": "(cf.person.bot)",
    "paused": "false",
    "priority": "1",
    "created_on": "2023-02-01T08:00:00Z"
  },
  {
    "id": "fw0002fai",
    "zone_id": "zone-MCWC Chronic Pain Program-ai-0001",
    "description": "Rate limit login endpoint",
    "action": "challenge",
    "expression": "(http.request.uri.path eq \"/auth/login\")",
    "paused": "false",
    "priority": "2",
    "created_on": "2023-03-01T08:00:00Z"
  },
  {
    "id": "fw0003fai",
    "zone_id": "zone-MCWC Chronic Pain Program-ai-0001",
    "description": "Block SQL injection attempts",
    "action": "block",
    "expression": "(http.request.uri.query contains \"SELECT\" or http.request.uri.query contains \"UNION\")",
    "paused": "false",
    "priority": "3",
    "created_on": "2023-02-15T08:00:00Z"
  },
  {
    "id": "fw0004api",
    "zone_id": "zone-MCWC Chronic Pain Program-api-0003",
    "description": "Require API key header",
    "action": "block",
    "expression": "(not http.request.headers[\"x-api-key\"] ne \"\")",
    "paused": "false",
    "priority": "1",
    "created_on": "2023-03-01T08:00:00Z"
  },
  {
    "id": "fw0005api",
    "zone_id": "zone-MCWC Chronic Pain Program-api-0003",
    "description": "Block non-US traffic to internal API",
    "action": "challenge",
    "expression": "(ip.geoip.country ne \"US\")",
    "paused": "false",
    "priority": "2",
    "created_on": "2024-01-10T08:00:00Z"
  },
  {
    "id": "fw0006app",
    "zone_id": "zone-MCWC Chronic Pain Program-app-0002",
    "description": "Block credential stuffing pattern",
    "action": "managed_challenge",
    "expression": "(http.request.method eq \"POST\" and http.request.uri.path contains \"/login\" and cf.threat_score gt 10)",
    "paused": "false",
    "priority": "1",
    "created_on": "2023-03-15T08:00:00Z"
  },
  {

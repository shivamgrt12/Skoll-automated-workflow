    "page_id": "pea790e4a248dab6ac4b6ae185444f25",
    "parent_block_id": "pea790e4a248dab6ac4b6ae185444f25",
    "text": "TFTEA drawback: substitution allowed for HTSUS 8-digit match. Simplifies claims but requires new inventory tracking method. Update Cleveland Ag Direct workflow.",
    "type": "paragraph"

    "page_id": "pea790e4a248dab6ac4b6ae185444f24",
    "parent_block_id": "pea790e4a248dab6ac4b6ae185444f24",
    "text": "List 3 exclusion status: many exclusions extended through 5/31/2026 per USTR notice. Verify specific tariff subheadings against updated exclusion list.",
    "type": "paragraph"
  },
  {
    "checked": "false",
    "created_time": "2026-04-03T15:30:00+00:00",
    "has_children": "false",
    "id": "bbcc226f9b5f74d1580f890d58e30307",

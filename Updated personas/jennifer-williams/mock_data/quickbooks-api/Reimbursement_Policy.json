{
  "policy_name": "Zine & Writing Expense Rules",
  "version": "2026.Q4",
  "validation_rules": [
    {
      "rule": "Printing",
      "requirement": "Zine print runs",
      "action": "Allow",
      "notes": "Counts against the $30/month zine printing fund"
    },
    {
      "rule": "Submission fees",
      "requirement": "Reading fees over $20",
      "action": "Manual Review",
      "notes": "Only for magazines that pay contributors"
    },
    {
      "rule": "Duplicates",
      "requirement": "Duplicate receipts",
      "action": "Reject",
      "notes": "One receipt per print run"
    },
    {
      "rule": "Postage",
      "requirement": "Zine shipping",
      "action": "Allow",
      "notes": "Match to an Etsy order"
    },
    {
      "rule": "Threshold",
      "requirement": "Any commitment at or above $50",
      "action": "Hold",
      "notes": "Requires Jennifer's explicit approval"
    }
  ],
  "context": "Rules used during reimbursement validation for conference meal receipts."
}

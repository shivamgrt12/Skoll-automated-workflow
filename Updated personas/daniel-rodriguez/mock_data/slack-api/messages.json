    "ts": "1759391438.000500",
    "user_id": "U002CARLOS"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": "0",
    "text": "2pm Tuesday, done. You guys always make the most of whatever I bring — easiest account I run in Charleston.",

    "ts": "2025-12-24T16:45:10+00:00",
    "user_id": "U004AMY"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "🙏",
    "reply_count": "0",
    "text": "she's lovely! ok sorry to pile on you on your day off. thanks for the recap 🙏",

[
  {
    "business_id": "yelp-al-ameer-dearborn-7f3a",
    "id": "rev-000001",
    "rating": "5",
    "text": "My default Dearborn order. The fattoush, the garlic, the warm bread - nothing on the table is filler. Brought my parents on a Sunday and we lingered for two hours.",
    "time_created": "2025-11-09 00:00:00",
    "user_name": "Ava R."
  },
  {
    "business_id": "yelp-al-ameer-dearborn-7f3a",
    "id": "rev-000002",
    "rating": "5",
    "text": "Late-night shawarma after a long press run. Consistent every single time, which is all I want from a neighborhood place.",
    "time_created": "2026-01-22 00:00:00",
    "user_name": "Liam T."
  },
  {
    "business_id": "yelp-buddys-pizza-dearborn-2c91",
    "id": "rev-000003",
    "rating": "4",
    "text": "Detroit-style done right - that caramelized cheese edge is the whole point. Half a pizza got me through an evening of layout revisions.",
    "time_created": "2025-12-03 00:00:00",
    "user_name": "Noah K."
  },
  {
    "business_id": "yelp-la-pita-fresh-dearborn-9d44",
    "id": "rev-000004",
    "rating": "4",
    "text": "Quick, fresh, and easy on the budget. The chicken shawarma wrap is my go-to between client visits.",
    "time_created": "2025-10-28 00:00:00",
    "user_name": "Mia S."
  },
  {
    "business_id": "yelp-avalon-breads-detroit-5b18",
    "id": "rev-000005",
    "rating": "5",
    "text": "The sea salt chocolate cookies and a loaf of motown multigrain are a standing weekend ritual. Warm earth tones everywhere, the kind of light I want my studio to have.",
    "time_created": "2025-11-30 00:00:00",
    "user_name": "Ethan B."
  },
  {
    "business_id": "yelp-astoria-pastry-detroit-3e62",
    "id": "rev-000006",
    "rating": "4",
    "text": "Greektown stop when I'm framing downtown. The almond croissant and a coffee while I wait on a pickup - small, civilized pleasure.",
    "time_created": "2026-02-14 00:00:00",
    "user_name": "Zoe M."
  },
  {
    "business_id": "yelp-anthology-coffee-detroit-8a07",
    "id": "rev-000007",
    "rating": "5",
    "text": "My pour-over of record. The Kenyan single origin is bright without being sharp, and the room is quiet enough to sketch lettering. I work better here than at home.",
    "time_created": "2025-10-19 00:00:00",
    "user_name": "Lucas P."
  },
  {
    "business_id": "yelp-anthology-coffee-detroit-8a07",
    "id": "rev-000008",
    "rating": "5",
    "text": "Came in to read on a slow morning and stayed to finish a brush-pen study. They take coffee seriously and never rush you out.",
    "time_created": "2026-01-11 00:00:00",
    "user_name": "Emma W."
  },
  {
    "business_id": "yelp-the-henry-dearborn-1f55",
    "id": "rev-000009",
    "rating": "4",
    "text": "Scouted it for a bridal client. Calm, neutral palette and good natural light for a welcome-table setup. Staff walked me through the floor plan without any pressure.",
    "time_created": "2025-12-18 00:00:00",
    "user_name": "Mason D."
  },
  {
    "business_id": "yelp-greenfield-village-events-6c20",
    "id": "rev-00000a",
    "rating": "5",
    "text": "Toured the event grounds for a fall wedding I am lettering signage for. The historic backdrop does half the design work for you - my place cards barely had to compete.",
    "time_created": "2026-02-27 00:00:00",
    "user_name": "Olivia F."
  },
  {
    "business_id": "yelp-detroit-foundation-hotel-4d83",
    "id": "rev-00000b",
    "rating": "4",
    "text": "Met a couple here to review their welcome packages. The lobby restaurant is a lovely place to spread out proofs, and the typography on their own menus is genuinely good.",
    "time_created": "2026-01-30 00:00:00",
    "user_name": "Jack H."
  },
  {
    "business_id": "yelp-cass-corridor-framing-0b96",
    "id": "rev-00000c",
    "rating": "5",
    "text": "Framed two lettering originals for a client install. They understood the deckled edges immediately and floated them perfectly - no glass glare, no fuss. Worth the price.",
    "time_created": "2025-11-15 00:00:00",
    "user_name": "Sofia L."
  },
  {
    "business_id": "yelp-mack-avenue-frame-shop-7e41",
    "id": "rev-00000d",
    "rating": "4",
    "text": "Good moulding selection in warm woods. Turnaround was a touch slow on a rush piece, but the finish was clean and the mat colors were spot on.",
    "time_created": "2026-03-05 00:00:00",
    "user_name": "Leo G."
  },
  {

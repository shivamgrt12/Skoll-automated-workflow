    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "8",
    "retweet_count": "3",
    "reply_count": "2",
    "quote_count": "1"
  },
  {
    "id": "9993769660145514880",
    "author_id": "3747882729217115656",
    "text": "Public lands deserve funding measured in decades, not appropriations.",
    "created_at": "2026-01-16T15:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "29",
    "retweet_count": "9",

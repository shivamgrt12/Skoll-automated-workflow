  },
  {
    "id": "9993769660145514876",
    "author_id": "3747882729217115656",
    "text": "Reading Chernow's Grant. Slow first hundred pages, then it sings.",
    "created_at": "2026-01-08T11:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "50",
    "retweet_count": "0",
    "reply_count": "5",
    "quote_count": "4"
  },
  {
    "id": "9993769660145514877",
    "author_id": "3747882729217115656",
    "text": "The CCC built parks we still walk in. Worth remembering who did the work.",
    "created_at": "2026-01-10T12:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "56",
    "retweet_count": "3",
    "reply_count": "9",
    "quote_count": "0"
  },
  {
    "id": "9993769660145514878",
    "author_id": "3747882729217115656",
    "text": "Safflower seed: keeps the squirrels honest and the cardinals loyal.",
    "created_at": "2026-01-12T13:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "13",

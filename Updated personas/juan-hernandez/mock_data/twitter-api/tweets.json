  {
    "id": "9993769660145514874",
    "author_id": "3747882729217115656",
    "text": "Thirty-five years reviewing land policy taught me one thing: the bay keeps a slower calendar than any budget cycle.",
    "created_at": "2026-01-04T09:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",

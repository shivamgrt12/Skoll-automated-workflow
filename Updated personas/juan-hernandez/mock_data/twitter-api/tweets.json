    "quote_count": "0"
  },
  {
    "id": "9993769660145514881",
    "author_id": "3747882729217115656",
    "text": "Osprey back on the Severn platforms. Spring, finally.",
    "created_at": "2026-01-18T16:00:00+00:00",

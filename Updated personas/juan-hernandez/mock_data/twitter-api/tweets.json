  },
  {
    "id": "9993769660145514875",
    "author_id": "3747882729217115656",
    "text": "First junco of the winter at the feeder this morning. The cold is coming.",
    "created_at": "2026-01-06T10:00:00+00:00",
    "lang": "en",
    "reply_to_tweet_id": "0",
    "like_count": "57",
    "retweet_count": "6",

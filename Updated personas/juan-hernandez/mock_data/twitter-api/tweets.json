  {
    "id": "9993769660145514873",
    "author_id": "3747882729217115656",
    "text": "My latest letter is up in the Capital Gazette on why the county's stormwater fee is worth keeping. Runoff into the Severn doesn't fix itself.",
    "created_at": "2026-01-02T08:00:00+00:00",

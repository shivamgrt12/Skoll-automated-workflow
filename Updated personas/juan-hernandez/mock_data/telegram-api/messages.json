  },
  {
    "message_id": "1000009",
    "chat_id": "id_000006",
    "from_id": "id_000000",
    "text": "Lenny's car is full with Doris, but the Annapolis route works. Come by 327 Munroe Court around 8 and we'll caravan down. I'll send the reminder the night before.",

[
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_001",
    "likeCount": 12,
    "moderationStatus": "published",
    "parentId": "Ugw7c1a9f3b2e8d4f5a6b00",
    "publishedAt": "2024-12-26T03:00:00Z",
    "textDisplay": "Good detail on the taper. I always overwork the ends. Going to slow down next cuff.",
    "updatedAt": "2024-12-26T03:00:00Z",
    "videoId": "vid_forge.cuff_001"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_002",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_001",
    "publishedAt": "2024-12-26T15:00:00Z",
    "textDisplay": "Anneal once more before you true the ends and it gets a lot easier.",
    "updatedAt": "2024-12-26T15:00:00Z",
    "videoId": "vid_forge.cuff_001"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_003",
    "likeCount": 9,
    "moderationStatus": "published",
    "parentId": "UgxA2d8e1f0c4b6a7e9d3f11",
    "publishedAt": "2024-03-30T01:00:00Z",
    "textDisplay": "What grit are you starting the dome at. Mine come out flat on top.",
    "updatedAt": "2024-03-30T01:00:00Z",
    "videoId": "vid_cut.cab_002"
  },
  {
    "authorChannelId": "UCsohamharrisonlapidary0",
    "authorDisplayName": "Soham Harrison",
    "channelId": "UCsohamharrisonlapidary0",
    "comment_id": "cmt_004",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_003",
    "publishedAt": "2024-03-30T04:00:00Z",
    "textDisplay": "80 grit to rough the dome, then I jump to 220. Keep it moving so you don't flat-spot it.",
    "updatedAt": "2024-03-30T04:00:00Z",
    "videoId": "vid_cut.cab_002"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_005",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "Ugw5f3c2b1a9e8d7f6c4b22",
    "publishedAt": "2023-03-27T09:00:00Z",
    "textDisplay": "Clean seam. I keep getting firescale right at the join. Probably too much heat.",
    "updatedAt": "2023-03-27T09:00:00Z",
    "videoId": "vid_solder.bez_003"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_006",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_005",
    "publishedAt": "2023-03-27T11:00:00Z",
    "textDisplay": "More flux and a softer flame at the end. Pull the heat the second it flows.",
    "updatedAt": "2023-03-27T11:00:00Z",
    "videoId": "vid_solder.bez_003"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_007",
    "likeCount": 3,
    "moderationStatus": "published",
    "parentId": "Ugy9e1d4c3b2a8f7e6d5c33",
    "publishedAt": "2023-03-27T12:00:00Z",
    "textDisplay": "Which stamp is that border. Looks like an old Mexican die.",
    "updatedAt": "2023-03-27T12:00:00Z",
    "videoId": "vid_stamp.pat_004"
  },
  {
    "authorChannelId": "UCjefffulkersonstamps0000",
    "authorDisplayName": "Jeff Fulkerson",
    "channelId": "UCjefffulkersonstamps0000",
    "comment_id": "cmt_008",
    "likeCount": 8,
    "moderationStatus": "published",
    "parentId": "cmt_007",
    "publishedAt": "2023-03-27T16:00:00Z",
    "textDisplay": "It's a hand-cut die I made. Happy to show the cutting in a later video.",
    "updatedAt": "2023-03-27T16:00:00Z",
    "videoId": "vid_stamp.pat_004"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_009",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugw3b8a7f6e5d4c2b1a0f44",
    "publishedAt": "2023-03-26T17:00:00Z",
    "textDisplay": "Pitch bowl is what's holding me back. Yours sits dead still.",
    "updatedAt": "2023-03-26T17:00:00Z",
    "videoId": "vid_repousse_005"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_010",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "cmt_009",
    "publishedAt": "2023-03-27T00:00:00Z",
    "textDisplay": "Warm the pitch with a heat gun, not a torch. Less mess and it grabs better.",
    "updatedAt": "2023-03-27T00:00:00Z",
    "videoId": "vid_repousse_005"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_011",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "Ugx8d2c1b0a9f8e7d6c5b55",
    "publishedAt": "2024-01-22T15:00:00Z",
    "textDisplay": "Spiny oyster always cracks on me when I burnish. Going slower helped here.",
    "updatedAt": "2024-01-22T15:00:00Z",
    "videoId": "vid_set.spiny_006"
  },
  {
    "authorChannelId": "UCsohamharrisonlapidary0",
    "authorDisplayName": "Soham Harrison",
    "channelId": "UCsohamharrisonlapidary0",
    "comment_id": "cmt_012",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_011",
    "publishedAt": "2024-01-22T21:00:00Z",
    "textDisplay": "Make sure the bezel is dead flush before you push. A high spot will crack the shell every time.",
    "updatedAt": "2024-01-22T21:00:00Z",
    "videoId": "vid_set.spiny_006"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_013",
    "likeCount": 3,
    "moderationStatus": "published",
    "parentId": "Ugw1a0f9e8d7c6b5a4f3e66",
    "publishedAt": "2024-03-25T12:00:00Z",
    "textDisplay": "Blade tension was my problem the whole time. Snapped a dozen before this clicked.",
    "updatedAt": "2024-03-25T12:00:00Z",
    "videoId": "vid_saw.curve_007"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_014",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_013",
    "publishedAt": "2024-03-25T15:00:00Z",
    "textDisplay": "Tight enough to ping. And let the blade do the cutting, don't force the turn.",
    "updatedAt": "2024-03-25T15:00:00Z",
    "videoId": "vid_saw.curve_007"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_015",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugy6c5b4a3f2e1d0c9b8a77",
    "publishedAt": "2025-10-06T18:00:00Z",
    "textDisplay": "What burnout schedule are you running. I keep getting incomplete fills on the hook.",
    "updatedAt": "2025-10-06T18:00:00Z",
    "videoId": "vid_cast.buckle_008"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_016",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "cmt_015",
    "publishedAt": "2025-10-07T18:00:00Z",
    "textDisplay": "Add a second sprue to the hook and bump your flask temp. Thin sections need the help.",
    "updatedAt": "2025-10-07T18:00:00Z",
    "videoId": "vid_cast.buckle_008"
  },
  {
    "authorChannelId": "UC_viewer_redrockmike0000",
    "authorDisplayName": "RedRockMike",
    "channelId": "UC_viewer_redrockmike0000",
    "comment_id": "cmt_017",
    "likeCount": 8,
    "moderationStatus": "published",
    "parentId": "Ugw4f3e2d1c0b9a8f7e6d88",
    "publishedAt": "2025-03-21T04:00:00Z",
    "textDisplay": "Clean work. Is that Sleeping Beauty going in the bezel.",
    "updatedAt": "2025-03-21T04:00:00Z",
    "videoId": "vid_sterling.c_009"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_018",
    "likeCount": 2,
    "moderationStatus": "published",
    "parentId": "cmt_017",
    "publishedAt": "2025-03-21T23:00:00Z",
    "textDisplay": "It is. Cut it from a slab last month. Setting clip goes up next.",
    "updatedAt": "2025-03-21T23:00:00Z",
    "videoId": "vid_sterling.c_009"
  },
  {
    "authorChannelId": "UC_viewer_zunigap00000000",
    "authorDisplayName": "ZuniGap",
    "channelId": "UC_viewer_zunigap00000000",
    "comment_id": "cmt_019",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugx7e6d5c4b3a2f1e0d9c99",
    "publishedAt": "2025-01-13T06:00:00Z",
    "textDisplay": "Nice even depth on that border. Hand or power hammer.",
    "updatedAt": "2025-01-13T06:00:00Z",
    "videoId": "vid_stamping.c_010"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_020",
    "likeCount": 2,
    "moderationStatus": "published",
    "parentId": "cmt_019",
    "publishedAt": "2025-01-13T12:00:00Z",
    "textDisplay": "All hand. One tap per strike, marked the spacing with dividers first.",
    "updatedAt": "2025-01-13T12:00:00Z",
    "videoId": "vid_stamping.c_010"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_021",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugw2d1c0b9a8f7e6d5c4b00",
    "publishedAt": "2026-01-17T13:00:00Z",
    "textDisplay": "Coral grain reading is the part I never get right. This helped.",
    "updatedAt": "2026-01-17T13:00:00Z",
    "videoId": "vid_polish.coral_015"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_022",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_021",
    "publishedAt": "2026-01-17T20:00:00Z",
    "textDisplay": "Hold it to the light and follow the lines. Cut along the grain, not across it.",
    "updatedAt": "2026-01-17T20:00:00Z",
    "videoId": "vid_polish.coral_015"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_023",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugy3c2b1a0f9e8d7c6b5a11",
    "publishedAt": "2023-12-05T10:00:00Z",
    "textDisplay": "Good tip on laying out for matrix. I waste too much slab guessing.",
    "updatedAt": "2023-12-05T10:00:00Z",
    "videoId": "vid_slab.royston_016"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_024",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_023",
    "publishedAt": "2023-12-06T07:00:00Z",
    "textDisplay": "Wet the slab and mark with a fine Sharpie. You see the matrix far better than dry.",
    "updatedAt": "2023-12-06T07:00:00Z",
    "videoId": "vid_slab.royston_016"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_025",
    "likeCount": 3,
    "moderationStatus": "published",
    "parentId": "Ugw9f8e7d6c5b4a3f2e1d22",
    "publishedAt": "2025-11-23T13:00:00Z",
    "textDisplay": "What epoxy holds up for channel inlay. Mine yellows over time.",
    "updatedAt": "2025-11-23T13:00:00Z",
    "videoId": "vid_channel.inlay_017"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_026",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_025",
    "publishedAt": "2025-11-23T23:00:00Z",
    "textDisplay": "Use a two-part jeweler's epoxy, not hardware-store stuff. The cheap kind ambers.",
    "updatedAt": "2025-11-23T23:00:00Z",
    "videoId": "vid_channel.inlay_017"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_027",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "Ugx5b4a3f2e1d0c9b8a7f33",
    "publishedAt": "2025-01-30T09:00:00Z",
    "textDisplay": "Dop wax temp tripped me up for years. Too hot and the stone moves.",
    "updatedAt": "2025-01-30T09:00:00Z",
    "videoId": "vid_grind.slab_018"
  },
  {
    "authorChannelId": "UCjefffulkersonstamps0000",
    "authorDisplayName": "Jeff Fulkerson",
    "channelId": "UCjefffulkersonstamps0000",
    "comment_id": "cmt_028",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_027",
    "publishedAt": "2025-01-30T20:00:00Z",
    "textDisplay": "Warm the stone first so the wax doesn't shock-cool. Sets centered every time.",
    "updatedAt": "2025-01-30T20:00:00Z",
    "videoId": "vid_grind.slab_018"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_029",
    "likeCount": 8,
    "moderationStatus": "published",
    "parentId": "Ugw6e5d4c3b2a1f0e9d8c44",
    "publishedAt": "2023-02-08T21:00:00Z",
    "textDisplay": "Tufa work is on my list. How many pours do you get from one carve.",
    "updatedAt": "2023-02-08T21:00:00Z",
    "videoId": "vid_buckle.back_019"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_030",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_029",
    "publishedAt": "2023-02-09T05:00:00Z",
    "textDisplay": "Three or four good ones before the detail softens. Recarve the lines and keep going.",
    "updatedAt": "2023-02-09T05:00:00Z",
    "videoId": "vid_buckle.back_019"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_031",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "Ugy8d7c6b5a4f3e2d1c0b55",
    "publishedAt": "2025-02-17T07:00:00Z",
    "textDisplay": "Bezel height is where I lose stones. You cut yours just shy of the dome.",
    "updatedAt": "2025-02-17T07:00:00Z",
    "videoId": "vid_bezel.dome_020"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_032",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_031",
    "publishedAt": "2025-02-18T01:00:00Z",
    "textDisplay": "Just past where the dome starts to curve in. Too tall and you can't push it clean.",
    "updatedAt": "2025-02-18T01:00:00Z",
    "videoId": "vid_bezel.dome_020"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_033",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugw0c9b8a7f6e5d4c3b2a66",
    "publishedAt": "2023-12-08T07:00:00Z",
    "textDisplay": "Reading the dull red in daylight is hard. I anneal at dusk now.",
    "updatedAt": "2023-12-08T07:00:00Z",
    "videoId": "vid_torch.basics_021"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_034",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "cmt_033",
    "publishedAt": "2023-12-08T18:00:00Z",
    "textDisplay": "Shade the bench or work after dark. The first faint red is all you need.",
    "updatedAt": "2023-12-08T18:00:00Z",
    "videoId": "vid_torch.basics_021"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_035",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugx1f0e9d8c7b6a5f4e3d77",
    "publishedAt": "2023-02-22T07:00:00Z",
    "textDisplay": "Dividers for spacing. Obvious now that I see it. Thanks.",
    "updatedAt": "2023-02-22T07:00:00Z",
    "videoId": "vid_stamp.layout_022"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_036",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_035",
    "publishedAt": "2023-02-22T16:00:00Z",
    "textDisplay": "Walk the dividers around once dry, then stamp. Keeps the whole run even.",
    "updatedAt": "2023-02-22T16:00:00Z",
    "videoId": "vid_stamp.layout_022"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_037",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugw7e6d5c4b3a2f1e0d9c88",
    "publishedAt": "2023-01-08T14:00:00Z",
    "textDisplay": "Liver of sulphur always goes too dark for me. The warm dip makes sense.",
    "updatedAt": "2023-01-08T14:00:00Z",
    "videoId": "vid_patina_023"
  },
  {
    "authorChannelId": "UCsohamharrisonlapidary0",
    "authorDisplayName": "Soham Harrison",
    "channelId": "UCsohamharrisonlapidary0",
    "comment_id": "cmt_038",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_037",
    "publishedAt": "2023-01-09T06:00:00Z",
    "textDisplay": "Dilute it and dip in short pulses. Easier to stop where you want the color.",
    "updatedAt": "2023-01-09T06:00:00Z",
    "videoId": "vid_patina_023"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_039",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "Ugx4d3c2b1a0f9e8d7c6b99",
    "publishedAt": "2023-02-03T23:00:00Z",
    "textDisplay": "Making my own bezel cups would save a fortune. Going to try the seam method.",
    "updatedAt": "2023-02-03T23:00:00Z",
    "videoId": "vid_make.bezel_024"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_040",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_039",
    "publishedAt": "2023-02-04T03:00:00Z",
    "textDisplay": "File the seam to a tight butt joint before you solder. No gap, no flooding.",
    "updatedAt": "2023-02-04T03:00:00Z",
    "videoId": "vid_make.bezel_024"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_041",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugw2c1b0a9f8e7d6c5b4a00",
    "publishedAt": "2023-01-10T05:00:00Z",
    "textDisplay": "Clean release on that dop. Mine always leave wax in the back.",
    "updatedAt": "2023-01-10T05:00:00Z",
    "videoId": "vid_dop.cab_025"
  },
  {
    "authorChannelId": "UCjefffulkersonstamps0000",
    "authorDisplayName": "Jeff Fulkerson",
    "channelId": "UCjefffulkersonstamps0000",
    "comment_id": "cmt_042",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_041",
    "publishedAt": "2023-01-10T12:00:00Z",
    "textDisplay": "Chill it in the freezer for a minute and the stone pops right off. Wax stays on the stick.",
    "updatedAt": "2023-01-10T12:00:00Z",
    "videoId": "vid_dop.cab_025"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_043",
    "likeCount": 8,
    "moderationStatus": "published",
    "parentId": "Ugy9d8c7b6a5f4e3d2c1b11",
    "publishedAt": "2024-01-28T22:00:00Z",
    "textDisplay": "Good layout on the lapidary corner. About to do the same in the garage.",
    "updatedAt": "2024-01-28T22:00:00Z",
    "videoId": "vid_studio.tour_026"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_044",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_043",
    "publishedAt": "2024-01-28T04:00:00Z",
    "textDisplay": "Keep the grinder away from the bench. Stone dust gets into everything otherwise.",
    "updatedAt": "2024-01-28T04:00:00Z",
    "videoId": "vid_studio.tour_026"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_045",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugw5c4b3a2f1e0d9c8b7a22",
    "publishedAt": "2025-10-05T01:00:00Z",
    "textDisplay": "Venting the tufa mold is the part I skip and regret. Clear here.",
    "updatedAt": "2025-10-05T01:00:00Z",
    "videoId": "vid_tufa.cast_027"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_046",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_045",
    "publishedAt": "2025-10-06T00:00:00Z",
    "textDisplay": "Cut the vents fine and angled up. The gases need somewhere to go or you get porosity.",
    "updatedAt": "2025-10-06T00:00:00Z",
    "videoId": "vid_tufa.cast_027"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_047",
    "likeCount": 9,
    "moderationStatus": "published",
    "parentId": "Ugx3b2a1f0e9d8c7b6a5f33",
    "publishedAt": "2024-01-25T11:00:00Z",
    "textDisplay": "The stabilized vs block part is gold. Got burned on a parcel last year.",
    "updatedAt": "2024-01-25T11:00:00Z",
    "videoId": "vid_id.turq_028"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_048",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "cmt_047",
    "publishedAt": "2024-01-25T18:00:00Z",
    "textDisplay": "Hot point test on an inconspicuous spot tells you fast. Block smells like plastic.",
    "updatedAt": "2024-01-25T18:00:00Z",
    "videoId": "vid_id.turq_028"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_049",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "Ugw6e5d4c3b2a1f0e9d8c44",
    "publishedAt": "2024-03-15T12:00:00Z",
    "textDisplay": "I always round my stamps over on the buffer. The wheel order here fixes that.",
    "updatedAt": "2024-03-15T12:00:00Z",
    "videoId": "vid_buffing_029"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_050",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_049",
    "publishedAt": "2024-03-15T15:00:00Z",
    "textDisplay": "Light touch and a soft wheel for the recesses. Let the compound do it, not pressure.",
    "updatedAt": "2024-03-15T15:00:00Z",
    "videoId": "vid_buffing_029"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_051",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugy4d3c2b1a0f9e8d7c6b55",
    "publishedAt": "2025-01-28T10:00:00Z",
    "textDisplay": "Cutting even prong seats is the hard part. Yours sit flush.",
    "updatedAt": "2025-01-28T10:00:00Z",
    "videoId": "vid_prong.set_030"
  },
  {
    "authorChannelId": "UCsohamharrisonlapidary0",
    "authorDisplayName": "Soham Harrison",
    "channelId": "UCsohamharrisonlapidary0",
    "comment_id": "cmt_052",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_051",
    "publishedAt": "2025-01-28T13:00:00Z",
    "textDisplay": "Use a setting bur the same size as your wire and go slow. Seats match every time.",
    "updatedAt": "2025-01-28T13:00:00Z",
    "videoId": "vid_prong.set_030"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_053",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugw1f0e9d8c7b6a5f4e3d66",
    "publishedAt": "2025-12-17T11:00:00Z",
    "textDisplay": "Truing the gap on the mandrel is what I rush. Mine never sit even on the wrist.",
    "updatedAt": "2025-12-17T11:00:00Z",
    "videoId": "vid_form.bracelet_031"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_054",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_053",
    "publishedAt": "2025-12-17T20:00:00Z",
    "textDisplay": "Mark the center, work both ends to it. Check the gap against the wrist before you set.",
    "updatedAt": "2025-12-17T20:00:00Z",
    "videoId": "vid_form.bracelet_031"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_055",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "Ugx8d7c6b5a4f3e2d1c0b77",
    "publishedAt": "2025-01-25T02:00:00Z",
    "textDisplay": "Twisted wire borders dress up a plain bezel. Going to set up a twisting jig.",
    "updatedAt": "2025-01-25T02:00:00Z",
    "videoId": "vid_twist.wire_032"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_056",
    "likeCount": 3,
    "moderationStatus": "published",
    "parentId": "cmt_055",
    "publishedAt": "2025-01-25T21:00:00Z",
    "textDisplay": "Two strands in a cordless drill works fine. Anneal before you solder it down.",
    "updatedAt": "2025-01-25T21:00:00Z",
    "videoId": "vid_twist.wire_032"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_057",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "Ugw9e8d7c6b5a4f3e2d1c88",
    "publishedAt": "2023-03-24T06:00:00Z",
    "textDisplay": "Getting symmetry by eye on a freeform is the skill. Templates help but the eye decides.",
    "updatedAt": "2023-03-24T06:00:00Z",
    "videoId": "vid_cab.layout_033"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_058",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_057",
    "publishedAt": "2023-03-24T15:00:00Z",
    "textDisplay": "Turn the stone over and over while you rough it. You catch the lopsided side fast.",
    "updatedAt": "2023-03-24T15:00:00Z",
    "videoId": "vid_cab.layout_033"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_059",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugx2c1b0a9f8e7d6c5b4a99",
    "publishedAt": "2024-03-17T03:00:00Z",
    "textDisplay": "Short and to the point. Quench timing was my missing piece.",
    "updatedAt": "2024-03-17T03:00:00Z",
    "videoId": "vid_anneal_034"
  },
  {
    "authorChannelId": "UCandycoopermanmetalwork",
    "authorDisplayName": "Andy Cooperman",
    "channelId": "UCandycoopermanmetalwork",
    "comment_id": "cmt_060",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_059",
    "publishedAt": "2024-03-17T12:00:00Z",
    "textDisplay": "Let it lose the red before you quench sterling or you can crack it. Air cool a beat.",
    "updatedAt": "2024-03-17T12:00:00Z",
    "videoId": "vid_anneal_034"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_061",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugw3b2a1f0e9d8c7b6a5f00",
    "publishedAt": "2025-03-11T22:00:00Z",
    "textDisplay": "Keeping the pickle active in a cold garage is a fight. Good notes here.",
    "updatedAt": "2025-03-11T22:00:00Z",
    "videoId": "vid_pickle_035"
  },
  {
    "authorChannelId": "UCsohamharrisonlapidary0",
    "authorDisplayName": "Soham Harrison",
    "channelId": "UCsohamharrisonlapidary0",
    "comment_id": "cmt_062",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_061",
    "publishedAt": "2025-03-12T01:00:00Z",
    "textDisplay": "A small crock pot on low keeps it warm and working. Cover it to slow evaporation.",
    "updatedAt": "2025-03-12T01:00:00Z",
    "videoId": "vid_pickle_035"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_063",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugy7e6d5c4b3a2f1e0d9c11",
    "publishedAt": "2024-11-20T09:00:00Z",
    "textDisplay": "Graver sharpening is the whole game. My cuts wander when it's dull.",
    "updatedAt": "2024-11-20T09:00:00Z",
    "videoId": "vid_engrave_036"
  },
  {
    "authorChannelId": "UClexierickson0000000000",
    "authorDisplayName": "Lexi Erickson",
    "channelId": "UClexierickson0000000000",
    "comment_id": "cmt_064",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "cmt_063",
    "publishedAt": "2024-11-20T20:00:00Z",
    "textDisplay": "Touch up the heel every few cuts. A sharp graver does the work, your hand just steers.",
    "updatedAt": "2024-11-20T20:00:00Z",
    "videoId": "vid_engrave_036"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_065",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "Ugw5c4b3a2f1e0d9c8b7a22",
    "publishedAt": "2025-11-28T20:00:00Z",
    "textDisplay": "Tube rivets are new to me. Useful when solder isn't an option on layered work.",
    "updatedAt": "2025-11-28T20:00:00Z",
    "videoId": "vid_rivet_037"
  },
  {
    "authorChannelId": "UCnancyhamiltonsilver0000",
    "authorDisplayName": "Nancy Hamilton",
    "channelId": "UCnancyhamiltonsilver0000",
    "comment_id": "cmt_066",
    "likeCount": 3,
    "moderationStatus": "published",
    "parentId": "cmt_065",
    "publishedAt": "2025-11-29T05:00:00Z",
    "textDisplay": "Flare both ends a little at a time, alternating. Even flares or the tube splits.",
    "updatedAt": "2025-11-29T05:00:00Z",
    "videoId": "vid_rivet_037"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_067",
    "likeCount": 5,
    "moderationStatus": "published",
    "parentId": "Ugx9d8c7b6a5f4e3d2c1b33",
    "publishedAt": "2024-01-19T03:00:00Z",
    "textDisplay": "Cerium on leather for the final. That's the step I was skipping on turquoise.",
    "updatedAt": "2024-01-19T03:00:00Z",
    "videoId": "vid_polish.turq_038"
  },
  {
    "authorChannelId": "UCmeganaumanmetal00000000",
    "authorDisplayName": "Megan Auman",
    "channelId": "UCmeganaumanmetal00000000",
    "comment_id": "cmt_068",
    "likeCount": 4,
    "moderationStatus": "published",
    "parentId": "cmt_067",
    "publishedAt": "2024-01-19T12:00:00Z",
    "textDisplay": "Clean the stone between every grit. One stray coarse particle ruins the polish.",
    "updatedAt": "2024-01-19T12:00:00Z",
    "videoId": "vid_polish.turq_038"
  },
  {
    "authorChannelId": "UC_viewer_redrockmike0000",
    "authorDisplayName": "RedRockMike",
    "channelId": "UC_viewer_redrockmike0000",
    "comment_id": "cmt_069",
    "likeCount": 7,
    "moderationStatus": "published",
    "parentId": "Ugw7f6e5d4c3b2a1f0e9d44",
    "publishedAt": "2025-10-19T03:00:00Z",
    "textDisplay": "Sensible layout. Where'd you mount the dust collection.",
    "updatedAt": "2025-10-19T03:00:00Z",
    "videoId": "vid_garage.studio_040"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_070",
    "likeCount": 2,
    "moderationStatus": "published",
    "parentId": "cmt_069",
    "publishedAt": "2025-10-19T12:00:00Z",
    "textDisplay": "Shop vac behind the lapidary bench, ducted out the side wall. Keeps the dust down.",
    "updatedAt": "2025-10-19T12:00:00Z",
    "videoId": "vid_garage.studio_040"
  },
  {
    "authorChannelId": "UC_viewer_kingmanruth0000",
    "authorDisplayName": "KingmanRuth",
    "channelId": "UC_viewer_kingmanruth0000",
    "comment_id": "cmt_071",
    "likeCount": 6,
    "moderationStatus": "published",
    "parentId": "Ugx1c0b9a8f7e6d5c4b3a55",
    "publishedAt": "2025-02-20T01:00:00Z",
    "textDisplay": "That Royston has good spiderweb. Where do you source your rough.",
    "updatedAt": "2025-02-20T01:00:00Z",
    "videoId": "vid_spiny.oyst_013"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_072",
    "likeCount": 2,
    "moderationStatus": "published",
    "parentId": "cmt_071",
    "publishedAt": "2025-02-20T17:00:00Z",
    "textDisplay": "A dealer out of Gallup, and the Tucson show in February. Buy by the slab when I can see it.",
    "updatedAt": "2025-02-20T17:00:00Z",
    "videoId": "vid_spiny.oyst_013"
  },
  {
    "authorChannelId": "UC_viewer_bolojohn000000",
    "authorDisplayName": "BoloJohn",
    "channelId": "UC_viewer_bolojohn000000",
    "comment_id": "cmt_073",
    "likeCount": 8,
    "moderationStatus": "published",
    "parentId": "Ugw3e2d1c0b9a8f7e6d5c66",
    "publishedAt": "2025-10-05T02:00:00Z",
    "textDisplay": "Clean slide. What length tips did you go with.",
    "updatedAt": "2025-10-05T02:00:00Z",
    "videoId": "vid_bolo.tie.s_014"
  },
  {
    "authorChannelId": "UCsamosborsamosbornexxxx",
    "authorDisplayName": "Osborne Metalworks",
    "channelId": "UCsamosborsamosbornexxxx",
    "comment_id": "cmt_074",
    "likeCount": 2,
    "moderationStatus": "published",
    "parentId": "cmt_073",
    "publishedAt": "2025-10-05T18:00:00Z",
    "textDisplay": "Inch and three quarter tips. Braided leather cord. Royston cab in the slide.",
    "updatedAt": "2025-10-05T18:00:00Z",
    "videoId": "vid_bolo.tie.s_014"
  }
]

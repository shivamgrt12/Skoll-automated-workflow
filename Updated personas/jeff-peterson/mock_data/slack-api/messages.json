    "thread_ts": "1769539372.000000",
    "ts": "1769539372.000002",
    "user_id": "U001PERSONA"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": 0,
    "text": "I'll grab the charges, meet you at the shack 6:15",
    "thread_ts": "1769539372.000000",
    "ts": "1769539372.000003",
    "user_id": "U005NATE"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": 0,
    "text": "Copy. Jake Tanner wants the advisory posted by 7 before lift ops",
    "thread_ts": "1769539372.000000",
    "ts": "1769539372.000004",
    "user_id": "U001PERSONA"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": 0,
    "text": "On it. Writing considerable, high on the lee aspects",
    "thread_ts": "1769539372.000000",
    "ts": "1769539372.000005",
    "user_id": "U005NATE"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": 0,
    "text": "Solid. Hey nice work on that quad set last night at Snow King",
    "thread_ts": "1769539372.000000",
    "ts": "1769539372.000006",
    "user_id": "U001PERSONA"
  },
  {
    "channel_id": "C001GENERA",
    "reactions": "",
    "reply_count": 0,
    "text": "Ha, barely walked today. See you at 6:15",

    "parent_block_id": "blk_notionroot",
    "type": "paragraph",
    "text": "Holly Hunt fall trade cocktails 11/19 Scottsdale showroom, 6 PM. RSVPd with +1 (Kevin).",
    "order": "6",
    "created_time": "2026-10-05T12:00:00+00:00",

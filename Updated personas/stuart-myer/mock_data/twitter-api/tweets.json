    "quote_count": "1",
    "reply_count": "5",
    "reply_to_tweet_id": "1740000000000000003",
    "retweet_count": "5",
    "text": "spent the morning water testing Johnson Creek with the coalition. cold hands, clean data. citizen science actually works."
  },
  {
    "author_id": "3132314894155184707",
    "created_at": "2025-12-23T05:00:05+00:00",
    "id": "9413431146417679991",

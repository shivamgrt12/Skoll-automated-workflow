    "like_count": "15",
    "quote_count": "0",
    "reply_count": "1",
    "reply_to_tweet_id": "1740000000000000004",
    "retweet_count": "4",
    "text": "wild ale's been in oak 14 months. tasted it straight from the barrel today, exactly where it should be. patience is a process variable."
  },
  {
    "author_id": "3132314894155184707",
    "created_at": "2025-12-25T16:21:01+00:00",
    "id": "3129833431914894846",

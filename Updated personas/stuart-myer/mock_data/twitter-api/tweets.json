    "like_count": "18",
    "quote_count": "0",
    "reply_count": "6",
    "reply_to_tweet_id": "1740000000000000005",
    "retweet_count": "4",
    "text": "clean source water isn't a luxury for a brewery, it's the whole recipe. protect the watershed."
  },

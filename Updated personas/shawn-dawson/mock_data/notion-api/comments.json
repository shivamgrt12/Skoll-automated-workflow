    "id": "d862ba02e557b7835e3d8537ed7202ac",
    "parent_block_id": "bea790e4a248dab6ac4b6ae1854467e4",
    "parent_page_id": "pea790e4a248dab6ac4b6ae1854464f7",
    "resolved": "true",
    "text": "Thanks for the heads up. I'll have Sofia loose by the third inning so we can pull Priya the moment her velo drops."
  },
  {
    "author_id": "u3b91d2c7f45a8e6019bd47c2a1e3f508",

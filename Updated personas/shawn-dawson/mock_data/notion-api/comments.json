    "parent_block_id": "bea790e4a248dab6ac4b6ae1854467ed",
    "parent_page_id": "pea790e4a248dab6ac4b6ae1854464f8",
    "resolved": "false",
    "text": "If we beat Troy in pool play we likely draw Novi in the semis. Want me to scout their Saturday game?"
  },
  {
    "author_id": "uea790e4a248dab6ac4b6ae1854463c7",

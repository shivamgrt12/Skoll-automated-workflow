    "id": "cea790e4a248dab6ac4b6ae185447756",
    "parent_block_id": "bea790e4a248dab6ac4b6ae1854467da",
    "parent_page_id": "pea790e4a248dab6ac4b6ae1854464f6",
    "resolved": "true",
    "text": "Paired Kayla and Tasha for DP turns and they're already in sync. Good chemistry up the middle."
  },
  {
    "author_id": "u2d8f6b1a9c43e7508b1d2f6a4e9c7031",
    "created_time": "2026-03-26T07:55:48+00:00",

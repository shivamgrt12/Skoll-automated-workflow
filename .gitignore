# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Node (opencode plugin deps, not needed by the skill)
node_modules/

# Local scratch / agent state
.sisyphus/

# Local harness backups (duplicated scratch copies, not needed in repo)
SKOLL_GK/*-backup*
SKOLL_GK/*.multiagent-backup

# Generated bundle outputs (keep the folder, ignore its contents)
Input_bundles_3rd_july/*
